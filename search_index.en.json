s-pt1/":{"tf":1.0}},"df":1}}}}}}},"u":{"docs":{},"df":0,"l":{"docs":{},"df":0,"d":{"docs":{},"df":0,"n":{"docs":{},"df":0,"’":{"docs":{},"df":0,"t":{"docs":{"https://nickscip.xyz/blog/learning-languages-pt1/":{"tf":1.0}},"df":1}}}}}}},"r":{"docs":{},"df":0,"i":{"docs":{},"df":0,"t":{"docs":{},"df":0,"e":{"docs":{"https://nickscip.xyz/":{"tf":1.0},"https://nickscip.xyz/blog/first/":{"tf":1.0}},"df":2}}}}}}},"title":{"root":{"docs":{},"df":0,"a":{"docs":{},"df":0,"i":{"docs":{"https://nickscip.xyz/blog/learning-languages-pt1/":{"tf":1.0}},"df":1}},"b":{"docs":{},"df":0,"l":{"docs":{},"df":0,"o":{"docs":{},"df":0,"g":{"docs":{"https://nickscip.xyz/blog/":{"tf":1.0},"https://nickscip.xyz/blog/first/":{"tf":1.0}},"df":2}}}},"c":{"docs":{},"df":0,"o":{"docs":{},"df":0,"m":{"docs":{},"df":0,"e":{"docs":{},"df":0,"d":{"docs":{"https://nickscip.xyz/blog/first/":{"tf":1.0}},"df":1}}}}},"e":{"docs":{},"df":0,"x":{"docs":{},"df":0,"i":{"docs":{},"df":0,"s":{"docs":{},"df":0,"t":{"docs":{"https://nickscip.xyz/blog/learning-languages-pt1/":{"tf":1.0}},"df":1}}}}},"h":{"docs":{},"df":0,"o":{"docs":{},"df":0,"m":{"docs":{},"df":0,"e":{"docs":{"https://nickscip.xyz/":{"tf":1.0}},"df":1}}}},"l":{"docs":{},"df":0,"e":{"docs":{},"df":0,"a":{"docs":{},"df":0,"r":{"docs":{},"df":0,"n":{"docs":{"https://nickscip.xyz/blog/learning-languages-pt1/":{"tf":1.0}},"df":1}}}}},"n":{"docs":{},"df":0,"o":{"docs":{},"df":0,"w":{"docs":{"https://nickscip.xyz/blog/learning-languages-pt1/":{"tf":1.0}},"df":1}}},"s":{"docs":{},"df":0,"e":{"docs":{},"df":0,"m":{"docs":{},"df":0,"i":{"docs":{"https://nickscip.xyz/blog/first/":{"tf":1.0}},"df":1}}},"p":{"docs":{},"df":0,"a":{"docs":{},"df":0,"n":{"docs":{},"df":0,"i":{"docs":{},"df":0,"s":{"docs":{},"df":0,"h":{"docs":{"https://nickscip.xyz/blog/learning-languages-pt1/":{"tf":1.0}},"df":1}}}}}}},"w":{"docs":{},"df":0,"r":{"docs":{},"df":0,"i":{"docs":{},"df":0,"t":{"docs":{},"df":0,"e":{"docs":{"https://nickscip.xyz/blog/first/":{"tf":1.0}},"df":1}}}}}}}},"documentStore":{"save":true,"docs":{"https://nickscip.xyz/":{"body":"Art by @pantspants\nNick Scipione\nAustin-based AI Engineer writing about whatever comes to mind\nCheck out my blog posts.","id":"https://nickscip.xyz/","title":"Home"},"https://nickscip.xyz/blog/":{"body":"","id":"https://nickscip.xyz/blog/","title":"Blog"},"https://nickscip.xyz/blog/first/":{"body":"You start.","id":"https://nickscip.xyz/blog/first/","title":"How to Write a Semi-Comedic Blog"},"https://nickscip.xyz/blog/learning-languages-pt1/":{"body":"The Quandry\nI’m learning Spanish as an adult.\nHave you tried learning a new language?\nMy previous few attempts were through school or university; but once classes ended, so did my literacy.\nThis time, I’m trying something different: spaced repetition via the lovely apps Anki and Natulang.\nThese systems sorta gameify learning through flashcards and daily practice, making it feel pleasurable.\nSnap-recalling the Spanish word for “pre-dawn” (la madrugada) is a very satisfying feeling.\nHowever, between these moments of blissful brain-etching, my pain-body interrupts with,\n“Whaddaya doin? Learnin language is a waste uh time once AI translators git good.”\nThis thought is learning friction.\nIt’s a new version of the classic “Why do I need to know math when calculators exist?”.\nThis gets at the main reason people learn languages: to communicate.\nOf course, there are other valid and noble causes: cultural preservation, the joy of learning itself, Italian opera singing.\nAnd like Latin speakers today, there will always be a small community of people dedicated to the craft.\nBut the vast majority learn as a means to an end.\nThey practice international business or they’re passport bros.\nIf a real Babel fish existed, the casual language learner wouldn’t.\nThe Duolingo Owl would be out of business, forced to sell talon pics.\nThe Audit\nA society-altering translation device would have the following features:\nMinimal Latency and High Accuracy: self-explanatory\nMultimodal: An effective human translator uses all of their senses to provide context, so a true Babel fish requires amazing microphones and cameras.\nWell, what is the current state of AI translation?\nIs there anything on the market that’s good enough to replace language learning?\nThe commercials for the latest Airpods or Meta Raybans sure portray them that way.\nFortunately for Duo, most reviews I’ve read found that the awkward silences and poor translations prevented the newest devices from being all that useful.\nFurthermore, none have weaved audio and vision into a worthwhile experience.\nThe Spiral\nA Universal Translator to replace human language learning is not here, yet.\nBut the basic components are, so it’s just a matter of time for the technology to improve.\nOnce this technology comes to fruition, it will open the doors for companies to hire anyone they want purely on skill.\nThe dating pool expands into an ocean of potential partners.\nAnyone who can’t access the device will be stuck with a pittance of languages while the rest ascend the Tower of Babel.\nAI will index entire dialects, so we never have to speak them again, like in the Season 1 finale of Pluribus when the hive mind absorbs the last remnants of Peruvian culture.\nThe language is digitized, but without any practitioners, it ceases to exist.\nWhew.\nSee the rabbit hole anxiety takes you down?\nPlanning around world-changing future tech is exhausting.\nFor now, I’ll continue learning Spanish.\nThe momentary doubts with infinite bottoms will also continue.","id":"https://nickscip.xyz/blog/learning-languages-pt1/","title":"Why Should I Learn Spanish Now That AI Exists?"}},"docInfo":{"https://nickscip.xyz/":{"body":16,"title":1},"https://nickscip.xyz/blog/":{"body":0,"title":1},"https://nickscip.xyz/blog/first/":{"body":1,"title":4},"https://nickscip.xyz/blog/learning-languages-pt1/":{"body":303,"title":5}},"length":4},"lang":"English"}